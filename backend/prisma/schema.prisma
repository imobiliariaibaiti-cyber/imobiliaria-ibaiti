generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id          Int      @id @default(autoincrement())
  propertyCode String?
  title       String
  type        String
  city        String
  address     String?
  latitude    Float?
  longitude   Float?
  areaSize    String?
  price       Int
  description String
  deedAndRegistryOk Boolean @default(false)
  featured    Boolean  @default(false)
  images      Json
  videoUrl    String?
  comments    Comment[]
  createdAt   DateTime @default(now())
}

model Comment {
  id         Int      @id @default(autoincrement())
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id])
  name       String
  contact    String?
  rating     Int      @default(5)
  text       String
  status     CommentStatus @default(PENDING)
  createdAt  DateTime @default(now())
}

model CitySummary {
  id        Int      @id @default(autoincrement())
  city      String   @unique
  summary   String?
  population Int?
  rating    Float?
  lat       Float?
  lng       Float?
  fetchedAt DateTime @default(now())
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

